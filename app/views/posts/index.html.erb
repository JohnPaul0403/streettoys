<% content_for :title, "Feed" %>

<section class="w-full space-y-8">
  <% if notice.present? %>
    <div class="alert alert-success" id="notice"><span><%= notice %></span></div>
  <% end %>

  <% if @posts.any? %>
    <div id="posts" class="grid gap-8">
      <% @posts.each do |post| %>
        <%= render post %>
      <% end %>
    </div>
  <% else %>
    <div class="hero rounded-[2%] border border-dashed border-base-300 bg-base-100 py-16 shadow-sm">
      <div class="hero-content text-center">
        <div class="max-w-md space-y-3">
          <h2 class="text-2xl font-black">No posts yet</h2>
          <p class="text-base-content/70">Start the feed by posting your first BMX or toy street photo set.</p>
          <%= link_to "Create a post", new_post_path, class: "btn btn-neutral" %>
        </div>
      </div>
    </div>
  <% end %>
</section>
