<%= form_with(model: post, class: "contents") do |form| %>
  <% if post.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-[2%] mt-3">
      <h2><%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:</h2>

      <ul class="list-disc ml-6">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :title %>
    <%= form.text_field :title, class: ["block shadow-sm rounded-[2%] border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-neutral": post.errors[:title].none?, "border-red-400 focus:outline-red-600": post.errors[:title].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :description %>
    <%= form.rich_textarea :description, rows: 4, class: ["block shadow-sm rounded-[2%] border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-neutral": post.errors[:description].none?, "border-red-400 focus:outline-red-600": post.errors[:description].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :images, "Photos" %>
    <%= form.file_field :images, multiple: true, accept: "image/*", class: "block w-full mt-2 text-sm file:mr-4 file:rounded-[2%] file:border-0 file:bg-neutral file:px-4 file:py-2 file:font-medium file:text-neutral-content hover:file:opacity-90" %>
    <p class="mt-2 text-sm text-gray-500">Upload one or more photos for the post.</p>
  </div>

  <% if post.images.attached? %>
    <div class="my-5">
      <p class="font-medium">Current photos</p>
      <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-3">
        <% post.images.each do |image| %>
          <%= image_tag image.variant(resize_to_limit: [300, 300]), class: "h-32 w-full rounded-[2%] object-cover" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :tag_list, "Tags" %>
    <%= form.text_field :tag_list, value: post.tag_list.join(", "), class: "block shadow-sm rounded-[2%] border border-gray-400 px-3 py-2 mt-2 w-full", placeholder: "bmx, street, rail" %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-[2%] px-3.5 py-2.5 bg-neutral hover:opacity-90 text-neutral-content inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
