<% content_for :title, @post.title.presence || "Post" %>

<section class="w-full space-y-8">
  <% if notice.present? %>
    <div class="alert alert-success" id="notice"><span><%= notice %></span></div>
  <% end %>

  <div class="space-y-3">
    <p class="text-sm uppercase tracking-[0.35em] text-base-content/40">Post detail</p>
    <h1 class="max-w-4xl text-4xl font-black leading-none tracking-tight sm:text-6xl"><%= @post.title.presence || "Untitled post" %></h1>
    <div class="flex flex-wrap items-center gap-3 text-sm text-base-content/55">
      <span><%= time_ago_in_words(@post.created_at) %> ago</span>
      <span class="h-1 w-1 rounded-full bg-base-content/30"></span>
      <% if @post.user.profile.present? %>
        <%= link_to "@#{profile_name_for(@post.user)}", profile_path(@post.user.profile), class: "font-semibold transition hover:opacity-70" %>
      <% else %>
        <span class="font-semibold">@<%= profile_name_for(@post.user) %></span>
      <% end %>
    </div>
  </div>

  <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <div class="space-y-6">
      <% cache post_gallery_cache_key(@post) do %>
        <% if @post.images.attached? %>
          <section class="space-y-4">
            <div class="overflow-hidden rounded-[2%] border border-base-300 bg-base-100 shadow-sm">
              <%= post_image_tag @post.images.first, class: "max-h-[42rem] w-full object-cover" %>
            </div>

            <% if @post.images.size > 1 %>
              <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                <% @post.images.drop(1).each do |image| %>
                  <div class="overflow-hidden rounded-[2%] border border-base-300 bg-base-100 shadow-sm">
                    <%= post_image_tag image, class: "aspect-[4/3] w-full object-cover" %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </section>
        <% end %>
      <% end %>

      <article class="rounded-[2%] border border-base-300 bg-base-100 p-6 shadow-sm sm:p-8">
        <% if @post.tag_list.any? %>
          <div class="mb-6 flex flex-wrap gap-2">
            <% @post.tag_list.each do |tag| %>
              <span class="rounded-full border border-base-300 px-3 py-1 text-[11px] uppercase tracking-[0.18em] text-base-content/60"><%= tag %></span>
            <% end %>
          </div>
        <% end %>

        <% if @post.description.present? %>
          <div class="prose prose-lg max-w-none text-base-content prose-headings:text-base-content prose-p:leading-8 prose-p:text-base-content/82">
            <%= @post.description %>
          </div>
        <% else %>
          <p class="text-base-content/60">No caption yet.</p>
        <% end %>
      </article>
    </div>

    <aside class="space-y-4">
      <% cache post_sidebar_cache_key(@post) do %>
        <div class="rounded-[2%] border border-base-300 bg-base-100 p-5 shadow-sm">
          <div class="space-y-5">
            <div class="space-y-1">
              <div class="text-[11px] uppercase tracking-[0.26em] text-base-content/40">Posted by</div>
              <div class="text-xl font-black">
                <% if @post.user.profile.present? %>
                  <%= link_to "@#{profile_name_for(@post.user)}", profile_path(@post.user.profile), class: "transition hover:opacity-70" %>
                <% else %>
                  @<%= profile_name_for(@post.user) %>
                <% end %>
              </div>
              <div class="text-sm text-base-content/58"><%= profile_title_for(@post.user) %></div>
            </div>

            <div class="flex items-center gap-3 rounded-[2%] border border-base-300 bg-base-200 px-4 py-3">
              <div class="avatar placeholder">
                <div class="w-12 rounded-[2%] border border-base-300 bg-base-100 text-base-content">
                  <span class="text-sm font-bold"><%= profile_name_for(@post.user).first(2).upcase %></span>
                </div>
              </div>
              <div class="text-sm text-base-content/70">Profile attached to this post.</div>
            </div>

            <% if @post.user.profile&.bio.present? %>
              <div class="prose prose-sm max-w-none text-base-content prose-p:leading-6 prose-p:text-base-content/74">
                <%= @post.user.profile.bio %>
              </div>
            <% else %>
              <p class="text-sm leading-6 text-base-content/60">This post is attached to a lightweight profile with no bio yet.</p>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="flex flex-wrap gap-2">
        <%= link_to "Back to feed", posts_path, class: "btn btn-ghost rounded-full px-5" %>
        <% if @post.user == Current.user %>
          <%= link_to "Edit post", edit_post_path(@post), class: "btn btn-neutral rounded-full px-5" %>
          <%= button_to "Delete", @post, method: :delete, class: "btn btn-ghost rounded-full px-5 text-error hover:bg-error/10", data: { turbo_confirm: "Delete this post?" } %>
        <% end %>
      </div>
    </aside>
  </div>
</section>
