<% content_for :title, "Edit profile" %>

<section class="w-full">
  <div class="mx-auto w-full max-w-3xl">
    <div class="card border border-base-300 bg-base-100 shadow-xl">
      <div class="card-body gap-6">
        <div class="space-y-2">
          <p class="text-sm uppercase tracking-[0.25em] text-base-content/50">Profile setup</p>
          <h1 class="text-4xl font-black tracking-tight">Edit your profile</h1>
          <p class="text-sm text-base-content/70">Update the identity attached to your posts.</p>
        </div>

        <%= render "form", profile: @profile %>

        <div class="flex flex-wrap gap-2">
          <%= link_to "View profile", @profile, class: "btn btn-neutral btn-outline" %>
          <%= link_to "Back to profiles", profiles_path, class: "btn btn-ghost" %>
        </div>
      </div>
    </div>
  </div>
</section>
