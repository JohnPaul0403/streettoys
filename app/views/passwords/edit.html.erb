<section class="hero w-full">
  <div class="hero-content w-full max-w-md px-0">
    <div class="card w-full bg-base-100 shadow-xl">
      <div class="card-body gap-5">
        <% if alert = flash[:alert] %>
          <div class="alert alert-error" id="alert"><span><%= alert %></span></div>
        <% end %>

        <div class="space-y-2">
          <h1 class="text-3xl font-black tracking-tight">Update password</h1>
          <p class="text-sm text-base-content/70">Choose a new password for your account.</p>
        </div>

        <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-4" do |form| %>
          <label class="form-control w-full">
            <div class="label">
              <span class="label-text">New password</span>
            </div>
            <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "At least 8 characters", maxlength: 72, class: "input input-bordered w-full" %>
          </label>

          <label class="form-control w-full">
            <div class="label">
              <span class="label-text">Confirm password</span>
            </div>
            <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Repeat your password", maxlength: 72, class: "input input-bordered w-full" %>
          </label>

          <%= form.submit "Save password", class: "btn btn-neutral w-full" %>
        <% end %>
      </div>
    </div>
  </div>
</section>
